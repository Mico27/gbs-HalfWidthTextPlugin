{
  "type": "enginePlugin",
  "name": "Half-Width Text Plugin",
  "author": "Mico27",
  "url": "https://github.com/Mico27/gbs-HalfWidthTextPlugin",
  "description": "Draws 4px-wide text (two characters per tile) using the Pokemon TCG technique: character pairs are composed into tiles on the fly and cached in VRAM with an LRU list, so repeated pairs reuse the same tile.",
  "license": "MIT",
  "version": "4.3.0",
  "gbsVersion": ">=4.3.0",
  "engineAltRules": [
    {
      "when": {
        "additionalPlugins": [
          "Mico27/ContinuousScenePlugin"
        ]
      },
      "use": "Cont"
    },
    {
      "when": {
        "additionalPlugins": [
          "ContinuousScenePlugin"
        ]
      },
      "use": "Cont"
    },
    {
      "when": {
        "additionalPlugins": [
          "Mico27/ScreenScrollPlugin"
        ]
      },
      "use": "Scr"
    },
    {
      "when": {
        "additionalPlugins": [
          "ScreenScrollPlugin"
        ]
      },
      "use": "Scr"
    }
  ]
}